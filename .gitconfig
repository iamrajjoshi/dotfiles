[user]
	name = Raj Joshi
	email = rajjoshi.0222@gmail.com
	signingkey = /Users/raj.joshi/.ssh/id_ed25519.pub
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[alias]
	a = commit --amend
	cm = commit -m
	co = checkout
	cob = checkout -b
	s = status
	uncommit = reset --soft HEAD^
	paid = push
	lg = log --graph --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --decorate=full
[push]
	autoSetupRemote = true
[include]
    path = ~/.gitconfig_local
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
[merge]
	conflictStyle = zdiff3
[gpg]
	format = ssh
[commit]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = /Users/raj.joshi/.ssh/allowed_signers
